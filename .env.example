# GA4
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=busta-revamped@1.0.0

# Consent defaults: denied | granted
VITE_MONITORING_DEFAULT_CONSENT=denied
VITE_MONITORING_CONSENT_KEY=busta.monitoring.consent

# SMTP Mail Configuration (PHP form handler — api.php)
# Copy these keys to .env and fill in real values. Never commit .env.
MAIL_HOST=
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=
MAIL_TO_ADDRESS=
